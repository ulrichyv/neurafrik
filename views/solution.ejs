<!DOCTYPE html>
<html class="dark" lang="<%= lang %>">
<head>
    <%- include('partials/head', { title: t.nav.solutions }) %>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased overflow-x-hidden">
    <%- include('partials/nav', { activePage: 'solution' }) %>

    <main class="pt-20">
        <!-- Solutions Hero -->
        <section class="relative py-20 overflow-hidden border-b border-white/10">
            <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, #bc00ff 1px, transparent 0); background-size: 40px 40px;"></div>
            <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
                <h1 class="text-4xl md:text-6xl font-black mb-6 tracking-tight leading-tight text-white">
                    <%= t.solution.title_1 %> <span class="text-primary"><%= t.solution.title_highlight %></span>
                </h1>
                <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
                    <%= t.solution.description %>
                </p>
        <!-- Solutions Grid -->
        <section class="py-24 px-6 bg-background-dark">
            <div class="max-w-7xl mx-auto">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    <!-- Card 1: Enterprise AI Strategy -->
                    <div class="group relative bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-primary/50 transition-all">
                        <div class="p-8 lg:p-10">
                            <span class="material-symbols-outlined text-primary text-4xl mb-4">architecture</span>
                            <h3 class="text-2xl font-bold mb-3 text-white">Enterprise AI Strategy</h3>
                            <p class="text-slate-300 mb-6 leading-relaxed">Comprehensive roadmap for AI adoption, from infra assessment to custom model development.</p>
                            <ul class="space-y-4 mb-8">
                                <li class="flex items-center gap-3 text-slate-200">
                                    <span class="material-symbols-outlined text-primary text-xl">check_circle</span> Infrastructure Readiness
                                </li>
                                <li class="flex items-center gap-3 text-slate-200">
                                    <span class="material-symbols-outlined text-primary text-xl">check_circle</span> Custom Model Training
                                </li>
                            </ul>
                            <div class="relative h-48 w-full rounded-xl bg-slate-900 border border-white/10 flex items-end justify-center overflow-hidden">
                                <div class="absolute inset-0 bg-gradient-to-t from-background-dark/80 to-transparent z-10"></div>
                                <div class="w-3/4 h-32 bg-slate-800 rounded-t-lg border-x border-t border-slate-700 p-4 transform translate-y-4 group-hover:translate-y-2 transition-transform">
                                    <div class="flex flex-col gap-2">
                                        <div class="h-2 w-1/2 bg-primary/20 rounded"></div>
                                        <div class="h-2 w-3/4 bg-slate-700 rounded"></div>
                                        <div class="h-2 w-2/3 bg-slate-700 rounded"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Card 2: AI Assistant for Sales -->
                    <div class="group relative bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-primary/50 transition-all">
                        <div class="p-8 lg:p-10">
                            <span class="material-symbols-outlined text-primary text-4xl mb-4">person_search</span>
                            <h3 class="text-2xl font-bold mb-3 text-white">AI Assistant for Sales Teams</h3>
                            <p class="text-slate-300 mb-6 leading-relaxed">Intelligent lead scoring and automated CRM management to help your team focus on closing high-value deals.</p>
                            <ul class="space-y-2 mb-8 text-sm text-slate-200">
                                <li class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary text-base">check_circle</span> Predictive Lead Scoring
                                </li>
                                <li class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary text-base">check_circle</span> CRM Enhancement & Enrichment
                                </li>
                            </ul>
                            <div class="relative h-48 w-full rounded-xl bg-slate-900 border border-white/10 flex items-center justify-center overflow-hidden">
                                <div class="absolute inset-0 bg-gradient-to-t from-background-dark/80 to-transparent z-10"></div>
                                <div class="w-4/5 grid grid-cols-2 gap-2 transform group-hover:scale-105 transition-transform">
                                    <div class="h-20 bg-primary/10 rounded border border-primary/20"></div>
                                    <div class="h-20 bg-slate-800 rounded border border-slate-700"></div>
                                    <div class="h-20 bg-slate-800 rounded border border-slate-700"></div>
                                    <div class="h-20 bg-primary/10 rounded border border-primary/20"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
