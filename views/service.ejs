<!DOCTYPE html>
<html class="dark" lang="<%= lang %>">
<head>
    <%- include('partials/head', { title: t.nav.services }) %>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased overflow-x-hidden">
    <%- include('partials/nav', { activePage: 'service' }) %>

    <main class="pt-20">
        <!-- Services Hero -->
        <section class="relative py-20 overflow-hidden border-b border-white/10">
            <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, #00eeff 1px, transparent 0); background-size: 40px 40px;"></div>
            <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
                <h1 class="text-4xl md:text-6xl font-black mb-6 tracking-tight leading-tight text-white">
                    <%= t.service.title %> <span class="text-primary"><%= t.service.title_highlight %></span>
                </h1>
                <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
                    <%= t.service.description %>
                </p>
            </div>
        </section>

        <!-- Services Grid -->
        <section class="py-24 px-6 bg-background-dark">
            <div class="max-w-7xl mx-auto">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <!-- Pillar 1: Automation -->
                    <div class="group p-10 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="size-16 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-primary text-4xl">settings_suggest</span>
                        </div>
                        <h3 class="text-3xl font-bold mb-6 text-white group-hover:text-primary transition-colors"><%= t.service.automation_title %></h3>
                        <p class="text-slate-300 leading-relaxed mb-8 text-lg"><%= t.service.automation_desc %></p>
                        <ul class="space-y-4 mb-10">
                            <li class="flex items-center gap-3 text-slate-200">
                                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
                                <%= t.service.automation_item1 %>
                            </li>
                            <li class="flex items-center gap-3 text-slate-200">
                                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
                                <%= t.service.automation_item2 %>
                            </li>
                        </ul>
                        <a href="/contact?lang=<%= lang %>" class="inline-block px-8 py-4 bg-primary text-background-dark font-bold rounded-xl hover:shadow-[0_0_30px_rgba(0,238,255,0.4)] transition-all">
                            <%= t.service.button_contact %>
                        </a>
                    </div>

                    <!-- Pillar 2: AI -->
                    <div class="group p-10 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="size-16 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-primary text-4xl">smart_toy</span>
                        </div>
                        <h3 class="text-3xl font-bold mb-6 text-white group-hover:text-primary transition-colors"><%= t.service.ai_title %></h3>
                        <p class="text-slate-300 leading-relaxed mb-8 text-lg"><%= t.service.ai_desc %></p>
                        <ul class="space-y-4 mb-10">
                            <li class="flex items-center gap-3 text-slate-200">
                                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
                                <%= t.service.ai_item1 %>
                            </li>
                            <li class="flex items-center gap-3 text-slate-200">
                                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
                                <%= t.service.ai_item2 %>
                            </li>
                        </ul>
                        <a href="/contact?lang=<%= lang %>" class="inline-block px-8 py-4 bg-primary text-background-dark font-bold rounded-xl hover:shadow-[0_0_30px_rgba(0,238,255,0.4)] transition-all">
                            <%= t.service.button_contact %>
                        </a>
                    </div>

                    <!-- Pillar 3: Development -->
                    <div class="group p-10 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="size-16 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-primary text-4xl">code</span>
                        </div>
                        <h3 class="text-3xl font-bold mb-6 text-white group-hover:text-primary transition-colors"><%= t.service.dev_title %></h3>
                        <p class="text-slate-300 leading-relaxed mb-8 text-lg"><%= t.service.dev_desc %></p>
                        <ul class="space-y-4 mb-10">
                            <li class="flex items-center gap-3 text-slate-200">
                                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
                                <%= t.service.dev_item1 %>
                            </li>
                            <li class="flex items-center gap-3 text-slate-200">
                                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
                                <%= t.service.dev_item2 %>
                            </li>
                        </ul>
                        <a href="/contact?lang=<%= lang %>" class="inline-block px-8 py-4 bg-primary text-background-dark font-bold rounded-xl hover:shadow-[0_0_30px_rgba(0,238,255,0.4)] transition-all">
                            <%= t.service.button_contact %>
                        </a>
                    </div>

                    <!-- Pillar 4: Data -->
                    <div class="group p-10 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="size-16 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-primary text-4xl">query_stats</span>
                        </div>
                        <h3 class="text-3xl font-bold mb-6 text-white group-hover:text-primary transition-colors"><%= t.service.data_title %></h3>
                        <p class="text-slate-300 leading-relaxed mb-8 text-lg"><%= t.service.data_desc %></p>
                        <ul class="space-y-4 mb-10">
                            <li class="flex items-center gap-3 text-slate-200">
                                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
                                <%= t.service.data_item1 %>
                            </li>
                            <li class="flex items-center gap-3 text-slate-200">
                                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
                                <%= t.service.data_item2 %>
                            </li>
                        </ul>
                        <a href="/contact?lang=<%= lang %>" class="inline-block px-8 py-4 bg-primary text-background-dark font-bold rounded-xl hover:shadow-[0_0_30px_rgba(0,238,255,0.4)] transition-all">
                            <%= t.service.button_contact %>
                        </a>
                    </div>

                    <!-- Pillar 5: Consulting -->
                    <div class="group p-10 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="size-16 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-primary text-4xl">lightbulb</span>
                        </div>
                        <h3 class="text-3xl font-bold mb-6 text-white group-hover:text-primary transition-colors"><%= t.service.consulting_title %></h3>
                        <p class="text-slate-300 leading-relaxed mb-8 text-lg"><%= t.service.consulting_desc %></p>
                        <ul class="space-y-4 mb-10">
                            <li class="flex items-center gap-3 text-slate-200">
                                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
                                <%= t.service.consulting_item1 %>
                            </li>
                            <li class="flex items-center gap-3 text-slate-200">
                                <span class="material-symbols-outlined text-primary text-xl">check_circle</span>
                                <%= t.service.consulting_item2 %>
                            </li>
                        </ul>
                        <a href="/contact?lang=<%= lang %>" class="inline-block px-8 py-4 bg-primary text-background-dark font-bold rounded-xl hover:shadow-[0_0_30px_rgba(0,238,255,0.4)] transition-all">
                            <%= t.service.button_contact %>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Process Timeline -->
        <section class="py-24 bg-background-dark/80 border-y border-white/10">
            <div class="max-w-7xl mx-auto px-6">
                <h2 class="text-3xl font-bold text-center mb-16 text-white"><%= t.service.engagement_title %> <span class="text-primary"><%= t.service.engagement_highlight %></span></h2>
                <div class="relative">
                    <!-- Line (Hidden on mobile) -->
                    <div class="hidden md:block absolute top-[28px] left-0 w-full h-1 bg-primary/20"></div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 relative z-10">
                        <!-- Step 1 -->
                        <div class="flex flex-col items-center text-center group">
                            <div class="size-14 rounded-full bg-background-dark border-4 border-primary/20 flex items-center justify-center mb-6 group-hover:border-primary transition-colors relative z-20">
                                <span class="text-primary font-bold text-lg">01</span>
                            </div>
                            <h3 class="text-xl font-bold mb-2 text-white"><%= t.service.process_1_title %></h3>
                            <p class="text-slate-300 text-sm"><%= t.service.process_1_desc %></p>
                        </div>
                        <!-- Step 2 -->
                        <div class="flex flex-col items-center text-center group">
                            <div class="size-14 rounded-full bg-background-dark border-4 border-primary/20 flex items-center justify-center mb-6 group-hover:border-primary transition-colors relative z-20">
                                <span class="text-primary font-bold text-lg">02</span>
                            </div>
                            <h3 class="text-xl font-bold mb-2 text-white"><%= t.service.process_2_title %></h3>
                            <p class="text-slate-300 text-sm"><%= t.service.process_2_desc %></p>
                        </div>
                        <!-- Step 3 -->
                        <div class="flex flex-col items-center text-center group">
                            <div class="size-14 rounded-full bg-background-dark border-4 border-primary/20 flex items-center justify-center mb-6 group-hover:border-primary transition-colors relative z-20">
                                <span class="text-primary font-bold text-lg">03</span>
                            </div>
                            <h3 class="text-xl font-bold mb-2 text-white"><%= t.service.process_3_title %></h3>
                            <p class="text-slate-300 text-sm"><%= t.service.process_3_desc %></p>
                        </div>
                        <!-- Step 4 -->
                        <div class="flex flex-col items-center text-center group">
                            <div class="size-14 rounded-full bg-background-dark border-4 border-primary flex items-center justify-center mb-6 group-hover:border-accent-purple transition-colors relative z-20">
                                <span class="text-primary font-bold text-lg">04</span>
                            </div>
                            <h3 class="text-xl font-bold mb-2 text-white"><%= t.service.process_4_title %></h3>
                            <p class="text-slate-300 text-sm"><%= t.service.process_4_desc %></p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
