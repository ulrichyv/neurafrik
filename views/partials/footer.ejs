<footer class="bg-background-dark py-12 md:py-16 px-6 lg:px-20 border-t border-white/10">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-12 mb-16">
            <div class="col-span-1 lg:col-span-1">
                <div class="flex items-center gap-3 mb-6">
                    <div class="size-14 flex items-center justify-center">
                        <img src="/assets/images/logo.png" alt="Neurafrik Logo" class="h-14 w-auto object-contain">
                    </div>
                    <h2 class="text-2xl font-bold tracking-tight">Neurafrik</h2>
                </div>
                <p class="text-slate-300 text-sm mb-6 leading-relaxed">
                    <%= t.footer.description %>
                </p>
                <div class="flex gap-4">
                    <a href="#"
                        class="size-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:border-primary/50 transition-colors">
                        <span class="material-symbols-outlined text-sm text-white/70">public</span>
                    </a>
                    <a href="#"
                        class="size-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:border-primary/50 transition-colors">
                        <span class="material-symbols-outlined text-sm text-white/70">share</span>
                    </a>
                </div>
            </div>

            <div>
                <h3 class="text-white font-bold mb-6">
                    <%= t.footer.solutions_title %>
                </h3>
                <ul class="space-y-4 text-sm text-slate-400">
                    <li><a href="/service?lang=<%= lang %>" class="hover:text-primary transition-colors">
                            <%= t.footer.automation %>
                        </a></li>
                    <li><a href="/service?lang=<%= lang %>" class="hover:text-primary transition-colors">
                            <%= t.footer.ai %>
                        </a></li>
                    <li><a href="/service?lang=<%= lang %>" class="hover:text-primary transition-colors">
                            <%= t.footer.development %>
                        </a></li>
                    <li><a href="/service?lang=<%= lang %>" class="hover:text-primary transition-colors">
                            <%= t.footer.data %>
                        </a></li>
                    <li><a href="/service?lang=<%= lang %>" class="hover:text-primary transition-colors">
                            <%= t.footer.consulting %>
                        </a></li>
                </ul>
            </div>

            <div>
                <h3 class="text-white font-bold mb-6">
                    <%= t.footer.company_title %>
                </h3>
                <ul class="space-y-4 text-sm text-slate-400">
                    <li><a href="/about?lang=<%= lang %>" class="hover:text-primary transition-colors">
                            <%= t.footer.about_us %>
                        </a></li>
                    <li><a href="/service?lang=<%= lang %>" class="hover:text-primary transition-colors">
                            <%= t.footer.our_services %>
                        </a></li>
                    <li><a href="/solution?lang=<%= lang %>" class="hover:text-primary transition-colors">
                            <%= t.footer.case_studies %>
                        </a></li>
                    <li><a href="/contact?lang=<%= lang %>" class="hover:text-primary transition-colors">
                            <%= t.footer.contact %>
                        </a></li>
                </ul>
            </div>

            <div>
                <h3 class="text-white font-bold mb-6">
                    <%= t.footer.office_title %>
                </h3>
                <ul class="space-y-4 text-sm text-slate-400">
                    <li class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary text-lg">location_on</span>
                        <span class="text-slate-300">Akwa,Cameroun</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary text-lg">mail</span>
                        <span class="text-slate-300">contact@neurafrik.com</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
            <p class="text-slate-400 text-xs">
                © 2024 Neurafrik Solutions. <%= t.footer.rights_reserved %>
            </p>
            <div class="flex gap-8 text-xs text-slate-400">
                <a href="#" class="hover:text-primary transition-colors">
                    <%= t.footer.privacy_policy %>
                </a>
                <a href="#" class="hover:text-primary transition-colors">
                    <%= t.footer.terms_of_service %>
                </a>
            </div>
        </div>
    </div>
</footer>