<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <%- include('../partials/head', { title: 'Events Admin' }) %>
</head>
<body class="bg-background-dark font-display text-slate-100 antialiased min-h-screen">
    
    <%- include('sidebar', { activeAdminPage: 'events' }) %>

    <main class="ml-72 p-8 lg:p-12">
        <header class="mb-10 flex justify-between items-end">
            <div>
                <p class="text-xs text-primary/70 uppercase tracking-widest font-bold mb-1">Admin / Contenu</p>
                <h1 class="text-3xl font-bold mb-1">Gestion des <span class="text-primary">Événements</span></h1>
                <p class="text-slate-400 text-sm">Créez et gérez les événements publiés sur le site.</p>
            </div>
            <a href="/event" target="_blank" class="flex items-center gap-2 text-xs text-slate-400 hover:text-primary transition-colors border border-white/10 px-4 py-2 rounded-xl hover:border-primary/30">
                <span class="material-symbols-outlined text-sm">open_in_new</span>
                Voir la page publique
            </a>
        </header>

        <div class="flex gap-8 items-start">

            <!-- === LEFT: Event List as Cards === -->
            <div class="flex-1">
                <% if (events && events.length > 0) { %>
                    <!-- Events Grid -->
                    <div class="grid grid-cols-1 xl:grid-cols-2 gap-5">
                        <% events.forEach(evt => { %>
                            <div class="glass-card rounded-2xl overflow-hidden flex flex-col neon-border transition-all group">
                                <!-- Event Image -->
                                <% if (evt.imageUrl) { %>
                                    <div class="h-40 w-full overflow-hidden relative">
                                        <img src="<%= evt.imageUrl %>" alt="<%= evt.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                        <div class="absolute inset-0 bg-gradient-to-t from-background-dark/80 to-transparent"></div>
                                        <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full text-[10px] font-bold border uppercase tracking-tight <%= evt.type === 'PAID' ? 'bg-accent-purple/80 text-white border-accent-purple/20' : 'bg-primary/80 text-background-dark border-primary/20' %>">
                                            <%= evt.type %>
                                        </span>
                                    </div>
                                <% } else { %>
                                    <div class="h-32 w-full flex items-center justify-center bg-gradient-to-br from-primary/5 to-background-dark relative">
                                        <span class="material-symbols-outlined text-5xl text-primary/30">event</span>
                                        <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full text-[10px] font-bold border uppercase tracking-tight <%= evt.type === 'PAID' ? 'bg-accent-purple/20 text-accent-purple border-accent-purple/20' : 'bg-primary/10 text-primary border-primary/20' %>">
                                            <%= evt.type %>
                                        </span>
                                    </div>
                                <% } %>

                                <!-- Event Content -->
                                <div class="p-5 flex flex-col flex-1">
                                    <p class="text-[10px] font-bold uppercase tracking-widest text-primary/70 mb-1"><%= evt.category || 'EVENT' %></p>
                                    <h3 class="text-base font-bold text-slate-100 mb-2 line-clamp-1"><%= evt.title %></h3>
                                    <p class="text-xs text-slate-400 line-clamp-2 mb-4"><%= evt.description %></p>
                                    
                                    <div class="mt-auto flex items-center justify-between pt-3 border-t border-primary/5">
                                        <div class="flex items-center gap-3 text-xs text-slate-400">
                                            <span class="flex items-center gap-1">
                                                <span class="material-symbols-outlined text-xs text-primary">calendar_today</span>
                                                <%= evt.date %>
                                            </span>
                                            <% if (evt.location) { %>
                                            <span class="flex items-center gap-1">
                                                <span class="material-symbols-outlined text-xs text-primary">location_on</span>
                                                <%= evt.location %>
                                            </span>
                                            <% } %>
                                        </div>
                                        <button onclick="if(confirm('Supprimer cet événement ?')) window.location.href='/admin/events/delete/<%= evt.id %>'"
                                            class="size-7 rounded-lg flex items-center justify-center text-slate-500 hover:bg-red-500/10 hover:text-red-400 transition-all inline-flex">
                                            <span class="material-symbols-outlined text-sm">delete</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="glass-card rounded-2xl p-16 text-center flex flex-col items-center gap-4">
                        <span class="material-symbols-outlined text-5xl text-primary/30">event_busy</span>
                        <p class="text-slate-400 text-sm">Aucun événement créé pour le moment.</p>
                        <p class="text-slate-500 text-xs">Utilisez le formulaire à droite pour commencer.</p>
                    </div>
                <% } %>
            </div>

            <!-- === RIGHT: Create Event Form === -->
            <div class="w-80 flex-shrink-0">
                <div class="glass-card rounded-2xl p-6 sticky top-8 neon-border transition-all">
                    <h3 class="text-base font-bold text-slate-100 mb-5 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">add_circle</span>
                        Créer un Événement
                    </h3>
                    <form action="/admin/events/create" method="POST" enctype="multipart/form-data" class="space-y-4">
                        
                        <!-- Image Upload -->
                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2">Image de l'événement</label>
                            <label for="eventImage" class="flex flex-col items-center justify-center w-full h-28 border-2 border-dashed border-primary/20 rounded-xl cursor-pointer bg-primary/5 hover:bg-primary/10 hover:border-primary/40 transition-all group" id="imageDropZone">
                                <div class="flex flex-col items-center justify-center gap-1" id="uploadLabel">
                                    <span class="material-symbols-outlined text-3xl text-primary/40 group-hover:text-primary/70 transition-colors">cloud_upload</span>
                                    <p class="text-xs text-slate-400 group-hover:text-slate-300">Cliquez pour choisir une image</p>
                                    <p class="text-[10px] text-slate-500">PNG, JPG, WEBP (max 5MB)</p>
                                </div>
                                <img id="imagePreview" class="hidden w-full h-full object-cover rounded-xl" />
                            </label>
                            <input id="eventImage" type="file" name="image" accept="image/*" class="hidden" onchange="previewImage(this)">
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Titre</label>
                            <input type="text" name="title" required class="w-full bg-primary/5 border border-primary/10 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/40 text-slate-100 transition-all">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Catégorie</label>
                            <input type="text" name="category" placeholder="WEBINAR, WORKSHOP..." required class="w-full bg-primary/5 border border-primary/10 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/40 text-slate-100 transition-all">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Description</label>
                            <textarea name="description" required rows="3" class="w-full bg-primary/5 border border-primary/10 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/40 text-slate-100 transition-all resize-none"></textarea>
                        </div>
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Date</label>
                                <input type="date" name="date" required class="w-full bg-primary/5 border border-primary/10 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/40 text-slate-300 transition-all">
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Type</label>
                                <select name="type" required class="w-full bg-background-dark border border-primary/10 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-primary/40 text-slate-100 transition-all">
                                    <option value="FREE">FREE</option>
                                    <option value="PAID">PAID</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Lieu</label>
                            <input type="text" name="location" placeholder="En ligne ou Ville" required class="w-full bg-primary/5 border border-primary/10 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/40 text-slate-100 transition-all">
                        </div>
                        <button type="submit" class="w-full bg-primary text-background-dark font-bold py-3 rounded-xl hover:shadow-[0_0_20px_rgba(0,238,255,0.4)] transition-all flex justify-center items-center gap-2 mt-2">
                            <span class="material-symbols-outlined">add</span> Créer l'événement
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </main>

    <script>
    function previewImage(input) {
        const preview = document.getElementById('imagePreview');
        const label = document.getElementById('uploadLabel');
        const dropZone = document.getElementById('imageDropZone');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                label.classList.add('hidden');
                dropZone.classList.add('p-0', 'overflow-hidden');
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
    </script>
</body>
</html>
