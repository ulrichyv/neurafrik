<!DOCTYPE html>
<html class="dark" lang="<%= lang %>">
<head>
    <%- include('../partials/head', { title: 'Dashboard Admin' }) %>
</head>
<body class="bg-background-dark font-display text-slate-100 antialiased min-h-screen">
    
    <%- include('sidebar', { activeAdminPage: 'dashboard' }) %>

    <main class="ml-72 p-8 lg:p-12">
        <header class="mb-12 flex justify-between items-end">
            <div>
                <h1 class="text-4xl font-black mb-2">Bon retour, <span class="text-primary">Admin 👋</span></h1>
                <p class="text-slate-400">Voici ce qui se passe sur Neurafrik aujourd'hui.</p>
            </div>
            <div class="text-right">
                <p class="text-sm text-slate-500 uppercase tracking-widest font-bold mb-1">Dernière mise à jour</p>
                <p class="text-sm font-bold"><%= new Date().toLocaleString('fr-FR') %></p>
            </div>
        </header>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
            <div class="glass-card p-6 rounded-2xl transition-all group hover:border-primary hover:shadow-[0_0_10px_rgba(0,238,255,0.3)]">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="text-slate-400 text-sm font-medium">Messages Reçus</p>
                        <h3 class="text-3xl font-bold text-slate-100 mt-2"><%= stats.messages %></h3>
                    </div>
                    <div class="size-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">mail</span>
                    </div>
                </div>
            </div>
            
            <div class="glass-card p-6 rounded-2xl transition-all group hover:border-primary hover:shadow-[0_0_10px_rgba(0,238,255,0.3)]">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="text-slate-400 text-sm font-medium">Abonnés Newsletter</p>
                        <h3 class="text-3xl font-bold text-slate-100 mt-2"><%= stats.subscribers %></h3>
                    </div>
                    <div class="size-10 rounded-lg bg-accent-purple/10 flex items-center justify-center text-accent-purple">
                        <span class="material-symbols-outlined">group</span>
                    </div>
                </div>
            </div>

            <div class="glass-card p-6 rounded-2xl transition-all group hover:border-primary hover:shadow-[0_0_10px_rgba(0,238,255,0.3)]">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="text-slate-400 text-sm font-medium">Nouveaux messages (24h)</p>
                        <h3 class="text-3xl font-bold text-slate-100 mt-2">+<%= stats.recentMessages %></h3>
                    </div>
                    <div class="size-10 rounded-lg bg-green-500/10 flex items-center justify-center text-green-400">
                        <span class="material-symbols-outlined">trending_up</span>
                    </div>
                </div>
            </div>

            <div class="glass-card p-6 rounded-2xl transition-all group hover:border-primary hover:shadow-[0_0_10px_rgba(0,238,255,0.3)]">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="text-slate-400 text-sm font-medium">Disponibilité Système</p>
                        <h3 class="text-3xl font-bold text-slate-100 mt-2">100%</h3>
                    </div>
                    <div class="size-10 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400">
                        <span class="material-symbols-outlined">speed</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
            <!-- Recent Messages -->
            <div class="lg:col-span-2 glass-card rounded-2xl overflow-hidden flex flex-col">
                <div class="p-6 border-b border-primary/10 flex items-center justify-between">
                    <h4 class="text-lg font-bold text-slate-100">Messages Récents</h4>
                    <a href="/admin/messages" class="text-primary text-xs font-semibold hover:underline">Voir tout</a>
                </div>
                <div class="flex-1 overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-[10px] uppercase tracking-wider text-slate-500 border-b border-primary/5">
                                <th class="px-6 py-4 font-bold">Client</th>
                                <th class="px-6 py-4 font-bold">Service</th>
                                <th class="px-6 py-4 font-bold border-none text-right">Date</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-primary/5">
                            <% recentSubmissions.forEach(sub => { %>
                                <tr class="hover:bg-primary/5 transition-colors cursor-pointer" onclick="window.location.href='/admin/messages'">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="size-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                                                <span class="material-symbols-outlined text-lg">person</span>
                                            </div>
                                            <div>
                                                <span class="text-sm font-semibold text-slate-200 block"><%= sub.fullName %></span>
                                                <span class="text-xs text-slate-400"><%= sub.email %></span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2.5 py-1 rounded-full bg-primary/10 text-primary text-[10px] font-bold border border-primary/20 uppercase tracking-tight"><%= sub.service %></span>
                                    </td>
                                    <td class="px-6 py-4 text-xs text-slate-400 text-right">
                                        <%= new Date(sub.timestamp).toLocaleDateString() %>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if (recentSubmissions.length === 0) { %>
                                <tr>
                                    <td colspan="3" class="px-6 py-12 text-center text-slate-500 text-sm">Aucun message pour le moment</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Quick Info / Actions -->
            <div class="space-y-8">
                <div class="p-8 rounded-[2.5rem] bg-gradient-to-br from-primary/20 via-primary/5 to-transparent border border-white/10">
                    <h3 class="text-xl font-bold mb-4">Exportation Data</h3>
                    <p class="text-slate-400 text-sm mb-6 leading-relaxed">Téléchargez vos listes de contacts et abonnés pour vos campagnes marketing.</p>
                    <button class="w-full py-4 rounded-2xl bg-white text-background-dark font-black hover:bg-primary transition-all active:scale-95 mb-4">
                        Exporter Contacts (CSV)
                    </button>
                    <button class="w-full py-4 rounded-2xl border border-white/20 text-white font-black hover:bg-white/10 transition-all active:scale-95">
                        Exporter NL (TXT)
                    </button>
                </div>

                <div class="p-8 rounded-[2.5rem] bg-white/5 border border-white/10">
                    <h3 class="text-xl font-bold mb-4">Support Neurafrik</h3>
                    <p class="text-slate-400 text-sm mb-6">Besoin d'aide avec votre interface de gestion ?</p>
                    <a href="mailto:support@neurafrik.com" class="text-primary font-bold flex items-center gap-2 group">
                        Contacter l'assistance
                        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </a>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
