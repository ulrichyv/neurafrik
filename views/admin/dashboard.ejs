<!DOCTYPE html>
<html class="dark" lang="<%= lang %>">
<head>
    <%- include('../partials/head', { title: 'Dashboard Admin' }) %>
</head>
<body class="bg-background-dark font-display text-slate-100 antialiased min-h-screen">
    
    <%- include('sidebar', { activeAdminPage: 'dashboard' }) %>

    <main class="ml-64 p-8 lg:p-12">
        <header class="mb-12 flex justify-between items-end">
            <div>
                <h1 class="text-4xl font-black mb-2">Bon retour, <span class="text-primary">Admin 👋</span></h1>
                <p class="text-slate-400">Voici ce qui se passe sur Neurafrik aujourd'hui.</p>
            </div>
            <div class="text-right">
                <p class="text-sm text-slate-500 uppercase tracking-widest font-bold mb-1">Dernière mise à jour</p>
                <p class="text-sm font-bold"><%= new Date().toLocaleString('fr-FR') %></p>
            </div>
        </header>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
            <div class="p-8 rounded-3xl bg-white/5 border border-white/10">
                <div class="size-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-6">
                    <span class="material-symbols-outlined">mail</span>
                </div>
                <p class="text-4xl font-black mb-1"><%= stats.messages %></p>
                <p class="text-slate-400 text-sm font-bold uppercase tracking-wider">Messages reçus</p>
            </div>
            
            <div class="p-8 rounded-3xl bg-white/5 border border-white/10">
                <div class="size-12 rounded-xl bg-accent-purple/10 flex items-center justify-center text-accent-purple mb-6">
                    <span class="material-symbols-outlined">group</span>
                </div>
                <p class="text-4xl font-black mb-1"><%= stats.subscribers %></p>
                <p class="text-slate-400 text-sm font-bold uppercase tracking-wider">Abonnés NL</p>
            </div>

            <div class="p-8 rounded-3xl bg-white/5 border border-white/10">
                <div class="size-12 rounded-xl bg-green-500/10 flex items-center justify-center text-green-400 mb-6">
                    <span class="material-symbols-outlined">trending_up</span>
                </div>
                <p class="text-4xl font-black mb-1">+<%= stats.recentMessages %></p>
                <p class="text-slate-400 text-sm font-bold uppercase tracking-wider">Nouveaux messages</p>
            </div>

            <div class="p-8 rounded-3xl bg-white/5 border border-white/10">
                <div class="size-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 mb-6">
                    <span class="material-symbols-outlined">speed</span>
                </div>
                <p class="text-4xl font-black mb-1">100%</p>
                <p class="text-slate-400 text-sm font-bold uppercase tracking-wider">Disponibilité</p>
            </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
            <!-- Recent Messages -->
            <div class="lg:col-span-2 rounded-[2.5rem] bg-white/5 border border-white/10 overflow-hidden flex flex-col">
                <div class="p-8 border-b border-white/10 flex justify-between items-center">
                    <h3 class="text-xl font-bold">Messages Récents</h3>
                    <a href="/admin/messages" class="text-primary text-sm font-bold hover:underline">Voir tout</a>
                </div>
                <div class="flex-1 overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-slate-500 text-xs uppercase tracking-widest border-b border-white/5">
                                <th class="px-8 py-4 font-bold">Client</th>
                                <th class="px-8 py-4 font-bold">Service</th>
                                <th class="px-8 py-4 font-bold">Date</th>
                                <th class="px-8 py-4 font-bold">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            <% recentSubmissions.forEach(sub => { %>
                                <tr class="hover:bg-white/5 transition-colors group">
                                    <td class="px-8 py-6">
                                        <div class="font-bold text-white"><%= sub.fullName %></div>
                                        <div class="text-xs text-slate-400"><%= sub.email %></div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-tighter">
                                            <%= sub.service %>
                                        </span>
                                    </td>
                                    <td class="px-8 py-6 text-sm text-slate-400">
                                        <%= new Date(sub.timestamp).toLocaleDateString() %>
                                    </td>
                                    <td class="px-8 py-6">
                                        <a href="/admin/messages?id=<%= sub.id %>" class="size-10 rounded-full flex items-center justify-center text-slate-400 hover:bg-white/10 hover:text-white transition-all">
                                            <span class="material-symbols-outlined">visibility</span>
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if (recentSubmissions.length === 0) { %>
                                <tr>
                                    <td colspan="4" class="px-8 py-12 text-center text-slate-500 italic">Aucun message pour le moment</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Quick Info / Actions -->
            <div class="space-y-8">
                <div class="p-8 rounded-[2.5rem] bg-gradient-to-br from-primary/20 via-primary/5 to-transparent border border-white/10">
                    <h3 class="text-xl font-bold mb-4">Exportation Data</h3>
                    <p class="text-slate-400 text-sm mb-6 leading-relaxed">Téléchargez vos listes de contacts et abonnés pour vos campagnes marketing.</p>
                    <button class="w-full py-4 rounded-2xl bg-white text-background-dark font-black hover:bg-primary transition-all active:scale-95 mb-4">
                        Exporter Contacts (CSV)
                    </button>
                    <button class="w-full py-4 rounded-2xl border border-white/20 text-white font-black hover:bg-white/10 transition-all active:scale-95">
                        Exporter NL (TXT)
                    </button>
                </div>

                <div class="p-8 rounded-[2.5rem] bg-white/5 border border-white/10">
                    <h3 class="text-xl font-bold mb-4">Support Neurafrik</h3>
                    <p class="text-slate-400 text-sm mb-6">Besoin d'aide avec votre interface de gestion ?</p>
                    <a href="mailto:support@neurafrik.com" class="text-primary font-bold flex items-center gap-2 group">
                        Contacter l'assistance
                        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </a>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
