<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <%- include('../partials/head', { title: 'Solutions Admin' }) %>
</head>
<body class="bg-background-dark font-display text-slate-100 antialiased min-h-screen">

    <%- include('sidebar', { activeAdminPage: 'solutions' }) %>

    <main class="ml-72 p-8 lg:p-12">
        <header class="mb-10 flex justify-between items-end">
            <div>
                <p class="text-xs text-primary/70 uppercase tracking-widest font-bold mb-1">Admin / Contenu</p>
                <h1 class="text-3xl font-bold mb-1">Gestion des <span class="text-primary">Solutions</span></h1>
                <p class="text-slate-400 text-sm">Créez et gérez les solutions affichées sur le site.</p>
            </div>
            <a href="/solution" target="_blank" class="flex items-center gap-2 text-xs text-slate-400 hover:text-primary transition-colors border border-white/10 px-4 py-2 rounded-xl hover:border-primary/30">
                <span class="material-symbols-outlined text-sm">open_in_new</span>
                Voir la page publique
            </a>
        </header>

        <div class="flex gap-8 items-start">

            <!-- === LEFT: Solutions Grid === -->
            <div class="flex-1">
                <% if (solutions && solutions.length > 0) { %>
                    <div class="grid grid-cols-1 xl:grid-cols-2 gap-5">
                        <% solutions.forEach(sol => { %>
                            <div class="glass-card rounded-2xl overflow-hidden flex flex-col neon-border transition-all group">
                                <!-- Image or Icon Banner -->
                                <% if (sol.imageUrl) { %>
                                    <div class="h-36 w-full overflow-hidden relative">
                                        <img src="<%= sol.imageUrl %>" alt="<%= sol.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                        <div class="absolute inset-0 bg-gradient-to-t from-background-dark/80 to-transparent"></div>
                                        <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight bg-primary/80 text-background-dark">
                                            <%= sol.category || 'SOLUTION' %>
                                        </span>
                                    </div>
                                <% } else { %>
                                    <div class="h-24 w-full flex items-center justify-center bg-gradient-to-br from-primary/5 to-background-dark relative">
                                        <span class="material-symbols-outlined text-5xl text-primary/40"><%= sol.icon || 'bolt' %></span>
                                        <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight bg-primary/10 text-primary border border-primary/20">
                                            <%= sol.category || 'SOLUTION' %>
                                        </span>
                                    </div>
                                <% } %>

                                <!-- Content -->
                                <div class="p-5 flex flex-col flex-1">
                                    <h3 class="text-base font-bold text-slate-100 mb-2 line-clamp-1"><%= sol.title %></h3>
                                    <p class="text-xs text-slate-400 line-clamp-2 mb-3"><%= sol.description %></p>

                                    <% if (sol.features && sol.features.length > 0) { %>
                                        <ul class="space-y-1 mb-4">
                                            <% sol.features.slice(0, 3).forEach(f => { %>
                                                <li class="flex items-center gap-2 text-xs text-slate-300">
                                                    <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
                                                    <%= f %>
                                                </li>
                                            <% }) %>
                                            <% if (sol.features.length > 3) { %>
                                                <li class="text-xs text-slate-500 italic pl-6">+<%= sol.features.length - 3 %> autres...</li>
                                            <% } %>
                                        </ul>
                                    <% } %>

                                    <div class="mt-auto pt-3 border-t border-primary/5 flex items-center justify-between">
                                        <span class="text-[10px] text-slate-500">
                                            <%= new Date(sol.createdAt).toLocaleDateString('fr-FR', {day:'2-digit', month:'short', year:'numeric'}) %>
                                        </span>
                                        <button onclick="if(confirm('Supprimer cette solution ?')) window.location.href='/admin/solutions/delete/<%= sol.id %>'"
                                            class="size-7 rounded-lg flex items-center justify-center text-slate-500 hover:bg-red-500/10 hover:text-red-400 transition-all inline-flex">
                                            <span class="material-symbols-outlined text-sm">delete</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="glass-card rounded-2xl p-16 text-center flex flex-col items-center gap-4">
                        <span class="material-symbols-outlined text-5xl text-primary/30">lightbulb</span>
                        <p class="text-slate-400 text-sm">Aucune solution créée pour le moment.</p>
                        <p class="text-slate-500 text-xs">Utilisez le formulaire à droite pour commencer.</p>
                    </div>
                <% } %>
            </div>

            <!-- === RIGHT: Create Solution Form === -->
            <div class="w-80 flex-shrink-0">
                <div class="glass-card rounded-2xl p-6 sticky top-8 neon-border transition-all">
                    <h3 class="text-base font-bold text-slate-100 mb-5 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">add_circle</span>
                        Créer une Solution
                    </h3>
                    <form action="/admin/solutions/create" method="POST" enctype="multipart/form-data" class="space-y-4">

                        <!-- Image Upload -->
                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2">Image (optionnelle)</label>
                            <label for="solutionImage" class="flex flex-col items-center justify-center w-full h-24 border-2 border-dashed border-primary/20 rounded-xl cursor-pointer bg-primary/5 hover:bg-primary/10 hover:border-primary/40 transition-all group" id="imageDropZone">
                                <div class="flex flex-col items-center justify-center gap-1" id="uploadLabel">
                                    <span class="material-symbols-outlined text-2xl text-primary/40 group-hover:text-primary/70 transition-colors">cloud_upload</span>
                                    <p class="text-xs text-slate-400">Cliquez pour choisir une image</p>
                                    <p class="text-[10px] text-slate-500">PNG, JPG, WEBP (max 5MB)</p>
                                </div>
                                <img id="imagePreview" class="hidden w-full h-full object-cover rounded-xl" />
                            </label>
                            <input id="solutionImage" type="file" name="image" accept="image/*" class="hidden" onchange="previewImage(this)">
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Titre</label>
                            <input type="text" name="title" required class="w-full bg-primary/5 border border-primary/10 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/40 text-slate-100 transition-all">
                        </div>

                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Icône Material</label>
                                <input type="text" name="icon" placeholder="bolt, lightbulb..." class="w-full bg-primary/5 border border-primary/10 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-primary/40 text-slate-100 transition-all">
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Catégorie</label>
                                <input type="text" name="category" placeholder="AI, DATA..." class="w-full bg-primary/5 border border-primary/10 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-primary/40 text-slate-100 transition-all">
                            </div>
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Description</label>
                            <textarea name="description" required rows="3" class="w-full bg-primary/5 border border-primary/10 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/40 text-slate-100 transition-all resize-none"></textarea>
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Fonctionnalités <span class="normal-case text-slate-500">(1 par ligne)</span></label>
                            <textarea name="features" rows="4" placeholder="Infrastructure Readiness&#10;Custom Model Training&#10;24/7 Support" class="w-full bg-primary/5 border border-primary/10 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-primary/40 focus:ring-1 focus:ring-primary/40 text-slate-100 transition-all resize-none"></textarea>
                        </div>

                        <button type="submit" class="w-full bg-primary text-background-dark font-bold py-3 rounded-xl hover:shadow-[0_0_20px_rgba(0,238,255,0.4)] transition-all flex justify-center items-center gap-2 mt-2">
                            <span class="material-symbols-outlined">add</span> Créer la Solution
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </main>

    <script>
    function previewImage(input) {
        const preview = document.getElementById('imagePreview');
        const label = document.getElementById('uploadLabel');
        const dropZone = document.getElementById('imageDropZone');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                label.classList.add('hidden');
                dropZone.classList.add('p-0', 'overflow-hidden');
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
    </script>
</body>
</html>
