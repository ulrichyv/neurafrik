<!-- Admin Sidebar -->
<div class="w-64 bg-slate-900/50 backdrop-blur-xl border-r border-white/10 flex flex-col h-screen fixed top-0 left-0 z-50">
    <div class="p-8 border-b border-white/10">
        <a href="/admin/dashboard" class="flex items-center gap-3 group">
            <img src="/assets/images/logo.png" alt="Logo" class="size-10 object-contain group-hover:scale-110 transition-transform">
            <span class="text-xl font-black">Neurafrik <span class="text-primary truncate">Admin</span></span>
        </a>
    </div>

    <nav class="flex-1 p-6 space-y-2 mt-4">
        <a href="/admin/dashboard" class="flex items-center gap-4 px-4 py-3 rounded-xl transition-all <%= activeAdminPage === 'dashboard' ? 'bg-primary text-background-dark font-bold' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
            <span class="material-symbols-outlined">dashboard</span>
            Tableau de bord
        </a>
        <a href="/admin/messages" class="flex items-center gap-4 px-4 py-3 rounded-xl transition-all <%= activeAdminPage === 'messages' ? 'bg-primary text-background-dark font-bold' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
            <span class="material-symbols-outlined">mail</span>
            Messages
        </a>
        <a href="/admin/subscribers" class="flex items-center gap-4 px-4 py-3 rounded-xl transition-all <%= activeAdminPage === 'subscribers' ? 'bg-primary text-background-dark font-bold' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
            <span class="material-symbols-outlined">group</span>
            Abonnés
        </a>
    </nav>

    <div class="p-6 border-t border-white/10">
        <div class="flex items-center gap-3 mb-6 px-4">
            <div class="size-10 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined">person</span>
            </div>
            <div class="overflow-hidden">
                <p class="text-xs text-slate-500 uppercase font-bold tracking-widest">Connecté en tant que</p>
                <p class="text-sm font-bold truncate">Administrateur</p>
            </div>
        </div>
        <a href="/admin/logout" class="flex items-center gap-4 px-4 py-3 rounded-xl text-red-400 hover:bg-red-500/10 transition-all font-bold">
            <span class="material-symbols-outlined">logout</span>
            Déconnexion
        </a>
    </div>
</div>
