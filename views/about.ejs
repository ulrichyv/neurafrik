<!DOCTYPE html>
<html class="dark" lang="<%= lang %>">
<head>
    <%- include('partials/head', { title: t.nav.about }) %>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased overflow-x-hidden">
    <%- include('partials/nav', { activePage: 'about' }) %>

    <main class="pt-20">
        <!-- About Hero -->
        <section class="px-6 py-20">
            <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
                <div>
                    <h1 class="text-4xl sm:text-5xl md:text-7xl font-black mb-8 tracking-tighter leading-tight text-white">
                        <%= t.about.title_part1 %> <br class="hidden sm:block"/><span class="text-primary"><%= t.about.title_highlight %></span>
                    </h1>
                    <p class="text-slate-300 text-lg md:text-xl leading-relaxed mb-8">
                        <%= t.about.description %>
                    </p>
                    
                    <div class="grid grid-cols-2 gap-8">
                        <div>
                            <p class="text-primary font-bold mb-2"><%= t.about.mission %></p>
                            <p class="text-sm text-slate-300"><%= t.about.mission_desc %></p>
                        </div>
                        <div>
                            <p class="text-primary font-bold mb-2"><%= t.about.value %></p>
                            <p class="text-sm text-slate-300"><%= t.about.value_desc %></p>
                        </div>
                    </div>
                </div>
                
                <div class="relative">
                    <div class="aspect-square rounded-[3rem] overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=1000" class="w-full h-full object-cover grayscale brightness-50" alt="Team">
                    </div>
                    <div class="absolute -bottom-10 -left-10 glass-nav p-8 rounded-3xl border border-white/10 hidden md:block">
                        <p class="text-4xl font-black text-primary mb-1">2024</p>
                        <p class="text-xs text-slate-400 uppercase tracking-widest"><%= t.about.foundation %></p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Values/Pillars -->
        <section class="py-32 px-6 bg-white/5 border-y border-white/10">
            <div class="max-w-7xl mx-auto">
                <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
                    <div class="max-w-2xl">
                        <h2 class="text-3xl md:text-5xl font-bold mb-6 text-white"><%= t.about.pillars_title %> <span class="text-primary">Innovation</span></h2>
                        <p class="text-slate-300"><%= t.about.pillars_description %></p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                    <div class="space-y-6">
                        <div class="text-primary">
                            <span class="material-symbols-outlined text-4xl">verified_user</span>
                        </div>
                        <h3 class="text-2xl font-bold text-white"><%= t.about.p1_title %></h3>
                        <p class="text-slate-300 leading-relaxed"><%= t.about.p1_desc %></p>
                    </div>
                    
                    <div class="space-y-6">
                        <div class="text-primary">
                            <span class="material-symbols-outlined text-4xl">language</span>
                        </div>
                        <h3 class="text-2xl font-bold text-white"><%= t.about.p2_title %></h3>
                        <p class="text-slate-300 leading-relaxed"><%= t.about.p2_desc %></p>
                    </div>
                    
                    <div class="space-y-6">
                        <div class="text-primary">
                            <span class="material-symbols-outlined text-4xl">trending_up</span>
                        </div>
                        <h3 class="text-2xl font-bold text-white"><%= t.about.p3_title %></h3>
                        <p class="text-slate-300 leading-relaxed"><%= t.about.p3_desc %></p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
