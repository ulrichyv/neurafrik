<!DOCTYPE html>
<html class="dark" lang="<%= lang %>">
<head>
    <%- include('partials/head', { title: t.nav.home }) %>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased overflow-x-hidden">
    <%- include('partials/nav', { activePage: 'home' }) %>

    <main>
        <!-- Hero Section -->
        <section class="relative min-h-screen flex flex-col items-center justify-center px-6 pt-20 hero-gradient">
            <div class="absolute inset-0 z-0 opacity-30 pointer-events-none" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCR0zJG0XUFVrWYBSfoQQfMBoX0szkELrO18InsPJpQDFU6G1t5Vh62ulOXbcGEEVO5YM4vV9TX3rzgyfQVC1f36YoXRUWqJYzx2e0wHYzfNwAYNt5lNRI6n6Lq3Q8VT6lXiiqBpIWQAKjQCe6K_wC6eNW1UnggMwQZNaA8OMLIZiQ4G384nb8oUqC7QeIXBF4vkmX0E0pOciXJOFgjW4c9MZs8ftW_z3JOACGCcEG3L4K1_LmXQ980Ine0Kg9_TnTLr7fMnNop2ad2'); background-size: cover; background-position: center;"></div>
            
            <div class="max-w-7xl mx-auto text-center relative z-10">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold uppercase tracking-wider mb-8">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                    </span>
                    <%= t.home.hero_badge %>
                </div>
                
                <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-black mb-8 tracking-tight leading-[1.1] md:leading-[0.9] text-white">
                    <%= t.home.hero_title_part1 %> <br class="hidden sm:block"/>
                    <span class="text-gradient"><%= t.home.hero_title_gradient %></span>
                </h1>
                
                <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed px-4">
                    <%= t.home.hero_description %>
                </p>
                
                <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                    <a href="/service?lang=<%= lang %>" class="w-full sm:w-auto px-8 py-4 rounded-xl bg-primary text-background-dark font-bold text-lg hover:shadow-[0_0_30px_rgba(0,238,255,0.6)] transition-all flex items-center justify-center text-center">
                        <%= t.home.get_started %>
                    </a>
                    <a href="/contact?lang=<%= lang %>" class="w-full sm:w-auto px-8 py-4 rounded-xl glass-nav bg-white/5 border border-white/10 text-white font-bold text-lg hover:bg-white/10 transition-all flex items-center justify-center text-center">
                        <%= t.home.book_consultation_hero %>
                    </a>
                </div>
            </div>

            <!-- Stats Bar -->
            <div class="relative md:absolute bottom-0 md:bottom-10 w-full max-w-4xl px-6 mt-12 md:mt-0">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8 glass-nav bg-white/5 border border-white/10 rounded-2xl p-6">
                    <div class="flex items-center gap-4 justify-center md:justify-start">
                        <span class="material-symbols-outlined text-primary text-3xl">rocket_launch</span>
                        <div>
                            <p class="text-2xl font-bold text-white">100+</p>
                            <p class="text-xs text-slate-300 uppercase tracking-widest"><%= t.home.stats_smes %></p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4 justify-center border-y md:border-y-0 md:border-x border-white/10 py-4 md:py-0">
                        <span class="material-symbols-outlined text-primary text-3xl">bolt</span>
                        <div>
                            <p class="text-2xl font-bold text-white">40%</p>
                            <p class="text-xs text-slate-300 uppercase tracking-widest"><%= t.home.stats_efficiency %></p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4 justify-center md:justify-end">
                        <span class="material-symbols-outlined text-primary text-3xl">public</span>
                        <div>
                            <p class="text-2xl font-bold text-white">5+</p>
                            <p class="text-xs text-slate-300 uppercase tracking-widest"><%= t.home.stats_countries %></p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Grid -->
        <section class="py-32 px-6">
            <div class="max-w-7xl mx-auto">
                <div class="text-center mb-20">
                    <h2 class="text-3xl md:text-5xl font-bold mb-6 text-white"><%= t.home.features_title_part1 %> <span class="text-primary"><%= t.home.features_title_highlight %></span></h2>
                    <p class="text-slate-300 max-w-2xl mx-auto"><%= t.home.features_description %></p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <!-- Feature 1: Automation -->
                    <div class="group p-8 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="size-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-primary text-3xl">settings_suggest</span>
                        </div>
                        <h3 class="text-2xl font-bold mb-4 text-white"><%= t.service.automation_title %></h3>
                        <p class="text-slate-300 leading-relaxed mb-6"><%= t.service.automation_desc %></p>
                        <a href="/service?lang=<%= lang %>" class="text-primary font-bold inline-flex items-center gap-2 group/link">
                            <%= t.home.learn_more %> <span class="material-symbols-outlined text-sm group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
                        </a>
                    </div>

                    <!-- Feature 2: AI -->
                    <div class="group p-8 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="size-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-primary text-3xl">smart_toy</span>
                        </div>
                        <h3 class="text-2xl font-bold mb-4 text-white"><%= t.service.ai_title %></h3>
                        <p class="text-slate-300 leading-relaxed mb-6"><%= t.service.ai_desc %></p>
                        <a href="/service?lang=<%= lang %>" class="text-primary font-bold inline-flex items-center gap-2 group/link">
                            <%= t.home.learn_more %> <span class="material-symbols-outlined text-sm group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
                        </a>
                    </div>

                    <!-- Feature 3: Development -->
                    <div class="group p-8 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="size-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-primary text-3xl">code</span>
                        </div>
                        <h3 class="text-2xl font-bold mb-4 text-white"><%= t.service.dev_title %></h3>
                        <p class="text-slate-300 leading-relaxed mb-6"><%= t.service.dev_desc %></p>
                        <a href="/service?lang=<%= lang %>" class="text-primary font-bold inline-flex items-center gap-2 group/link">
                            <%= t.home.learn_more %> <span class="material-symbols-outlined text-sm group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
                        </a>
                    </div>

                    <!-- Feature 4: Data -->
                    <div class="group p-8 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="size-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-primary text-3xl">query_stats</span>
                        </div>
                        <h3 class="text-2xl font-bold mb-4 text-white"><%= t.service.data_title %></h3>
                        <p class="text-slate-300 leading-relaxed mb-6"><%= t.service.data_desc %></p>
                        <a href="/service?lang=<%= lang %>" class="text-primary font-bold inline-flex items-center gap-2 group/link">
                            <%= t.home.learn_more %> <span class="material-symbols-outlined text-sm group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
                        </a>
                    </div>

                    <!-- Feature 5: Consulting -->
                    <div class="group p-8 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                        <div class="size-14 rounded-2xl bg-primary/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-primary text-3xl">lightbulb</span>
                        </div>
                        <h3 class="text-2xl font-bold mb-4 text-white"><%= t.service.consulting_title %></h3>
                        <p class="text-slate-300 leading-relaxed mb-6"><%= t.service.consulting_desc %></p>
                        <a href="/service?lang=<%= lang %>" class="text-primary font-bold inline-flex items-center gap-2 group/link">
                            <%= t.home.learn_more %> <span class="material-symbols-outlined text-sm group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-32 px-6">
            <div class="max-w-5xl mx-auto rounded-[3rem] bg-gradient-to-br from-primary/20 via-accent-purple/10 to-transparent p-12 md:p-24 text-center border border-white/10 relative overflow-hidden">
                <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, #fff 1px, transparent 0); background-size: 24px 24px;"></div>
                <h2 class="text-4xl md:text-6xl font-black mb-8 text-white"><%= t.home.cta_title_part1 %> <br/><span class="text-primary"><%= t.home.cta_title_highlight %></span></h2>
                <p class="text-slate-300 text-xl mb-12 max-w-2xl mx-auto leading-relaxed"><%= t.home.cta_description %></p>
                <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
                    <a href="/contact?lang=<%= lang %>" class="w-full sm:w-auto px-10 py-5 bg-primary text-background-dark font-black rounded-2xl text-xl hover:shadow-[0_0_40px_rgba(0,238,255,0.4)] transition-all flex items-center justify-center text-center">
                        <%= t.home.launch_consultation %>
                    </a>
                    <a href="/contact?lang=<%= lang %>" class="text-white font-bold text-xl hover:text-primary transition-colors"><%= t.home.talk_expert %></a>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
